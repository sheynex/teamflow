rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Documents collection
    match /documents/{fileId} {
      allow read, write: if request.auth != null;
    }
    
    // Task attachments
    match /tasks/{taskId}/{fileId} {
      allow read, write: if request.auth != null;
    }
    
    // Document versions
    match /versions/{docId}/{fileId} {
      allow read, write: if request.auth != null;
    }

    // Default fallback
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
